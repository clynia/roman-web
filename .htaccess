# Forzar UTF-8 (algunos hosts no envían charset y rompen los acentos)
AddDefaultCharset UTF-8

# URLs limpias: sin .html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^ / [R=301,L]
  RewriteCond %{THE_REQUEST} \s/+([^\s?]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
<IfModule mod_mime.c>
  AddCharset UTF-8 .html .css .js .xml .svg .json .webmanifest
</IfModule>

# No cachear HTML/CSS/JS: que cada visita reciba siempre la última versión
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
